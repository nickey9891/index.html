<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1a2e; --cream: #faf7f2; --gold: #c9a84c; --gold-light: #f0e2b6;
    --red: #c0392b; --green: #2d6a4f; --green-light: #d8f3dc;
    --blue: #1d3557; --blue-light: #e8f1f8; --orange: #e07b39;
    --orange-light: #fdebd0; --gray: #8a8a8a; --border: #e0d8cc;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'DM Sans',sans-serif; background:var(--cream); color:var(--ink); min-height:100vh; padding:24px 16px; }
  .page { max-width:860px; margin:0 auto; }

  .header { text-align:center; margin-bottom:28px; padding-bottom:20px; border-bottom:2px solid var(--gold); }
  .header-label { font-size:11px; font-weight:600; letter-spacing:3px; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
  .header h1 { font-family:'DM Serif Display',serif; font-size:36px; color:var(--ink); line-height:1; margin-bottom:4px; }
  .header-sub { font-size:13px; color:var(--gray); font-weight:300; }

  .summary-bar {
    display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:28px;
  }
  .summary-card { background:var(--ink); color:white; border-radius:12px; padding:14px 16px; text-align:center; }
  .summary-card .slbl { font-size:10px; letter-spacing:2px; text-transform:uppercase; color:var(--gold); margin-bottom:4px; }
  .summary-card .sval { font-family:'DM Serif Display',serif; font-size:20px; }

  .month-group { margin-bottom:8px; }
  .month-divider {
    text-align:center; font-family:'DM Serif Display',serif; font-size:24px;
    color:var(--ink); margin:28px 0 12px; padding-bottom:8px;
    border-bottom:2px solid var(--gold); position:sticky; top:0;
    background:var(--cream); z-index:10; padding-top:8px;
  }

  .paycheck-section { margin-bottom:16px; border:1.5px solid var(--border); border-radius:16px; overflow:hidden; }
  .section-header { display:flex; justify-content:space-between; align-items:center; padding:12px 18px; background:var(--ink); color:white; }
  .section-header .title { font-family:'DM Serif Display',serif; font-size:17px; }
  .section-header .subtitle { font-size:10px; color:rgba(255,255,255,0.5); letter-spacing:1px; text-transform:uppercase; margin-top:2px; }
  .section-header .paycheck-amt { text-align:right; }
  .section-header .paycheck-amt .label { font-size:9px; color:rgba(255,255,255,0.5); text-transform:uppercase; letter-spacing:1px; }
  .section-header .paycheck-amt .value { font-family:'DM Serif Display',serif; font-size:18px; color:var(--gold); }

  .bill-row { display:grid; grid-template-columns:52px 1fr 70px 36px; align-items:center; padding:10px 18px; border-bottom:1px solid var(--border); gap:8px; transition:background .15s; }
  .bill-row:hover { background:#f5f0e8; }
  .bill-due { font-size:10px; font-weight:600; color:var(--gold); background:var(--gold-light); border-radius:6px; padding:3px 4px; text-align:center; }
  .bill-name { font-size:13px; font-weight:500; color:var(--ink); }
  .bill-category { font-size:9px; color:var(--gray); text-transform:uppercase; letter-spacing:0.5px; margin-top:1px; }
  .bill-amount { font-size:14px; font-weight:600; color:var(--red); text-align:right; }
  .bill-check { width:26px; height:26px; border:2px solid var(--border); border-radius:6px; margin-left:auto; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .2s; flex-shrink:0; }
  .bill-check:hover { border-color:var(--green); background:var(--green-light); }
  .bill-check.checked { background:var(--green); border-color:var(--green); }
  .bill-check.checked::after { content:'✓'; color:white; font-size:13px; font-weight:700; }

  .subtotal-row { display:grid; grid-template-columns:1fr auto auto; padding:10px 18px; background:var(--blue-light); gap:20px; align-items:center; }
  .subtotal-row .label { font-size:11px; font-weight:600; color:var(--blue); text-transform:uppercase; letter-spacing:1px; }
  .subtotal-row .total-amt { font-family:'DM Serif Display',serif; font-size:16px; color:var(--red); }
  .subtotal-row .remaining { font-family:'DM Serif Display',serif; font-size:16px; min-width:70px; text-align:right; }

  .income-row { display:grid; grid-template-columns:52px 1fr 70px 36px; align-items:center; padding:10px 18px; background:var(--green-light); border-top:1px solid var(--border); gap:8px; }
  .info-row { display:grid; grid-template-columns:32px 1fr; align-items:center; padding:10px 18px; background:var(--orange-light); border-top:1px solid var(--border); gap:8px; }
  .good-row { background:#edf7f0; }
  .danger-row { background:#fde8e8; }

  .tips-box { background:white; border:1.5px solid var(--border); border-radius:16px; padding:18px 20px; margin:24px 0; }
  .tips-box h3 { font-family:'DM Serif Display',serif; font-size:18px; margin-bottom:12px; color:var(--ink); }
  .tip-item { display:flex; gap:10px; margin-bottom:9px; align-items:flex-start; }
  .tip-icon { font-size:15px; flex-shrink:0; margin-top:1px; }
  .tip-text { font-size:12px; color:#555; line-height:1.5; }
  .tip-text strong { color:var(--ink); }

  .footer { text-align:center; padding-top:20px; border-top:1px solid var(--border); font-size:12px; color:var(--gray); margin-top:16px; }
  .footer strong { font-family:'DM Serif Display',serif; font-size:16px; color:var(--green); display:block; margin-bottom:4px; }

  .tight-checks {
    background:var(--ink); border-radius:16px; padding:20px; margin-bottom:24px; color:white;
  }
  .tight-checks h2 { font-family:'DM Serif Display',serif; font-size:20px; color:var(--gold); margin-bottom:14px; }
  .tight-row { display:grid; grid-template-columns:140px 1fr auto; gap:12px; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.08); align-items:center; }
  .tight-row:last-child { border-bottom:none; }
  .tight-date { font-size:12px; color:var(--gold); font-weight:600; }
  .tight-note { font-size:12px; color:rgba(255,255,255,0.7); }
  .tight-amt { font-family:'DM Serif Display',serif; font-size:16px; text-align:right; }
  .tight-amt.neg { color:#e63946; }
  .tight-amt.low { color:#f9c74f; }
  .tight-amt.ok { color:#74c69d; }

  @media (max-width:600px) {
    .summary-bar { grid-template-columns:1fr 1fr; }
    .header h1 { font-size:28px; }
    .tight-row { grid-template-columns:110px 1fr auto; }
  }
</style>
</head>
